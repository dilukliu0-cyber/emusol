{
  "name": "@emusol/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Emusol desktop launcher",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on dist-electron/main.js http-get://127.0.0.1:5173 && electron dist-electron/main.js",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "preview": "npm run build && electron dist-electron/main.js --static",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "nostalgist": "^0.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@emulatorjs/core-desmume": "^4.2.3",
    "@emulatorjs/core-parallel_n64": "^4.2.3",
    "@types/node": "^20.17.19",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.emusol.desktop",
    "productName": "Emusol",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games",
      "artifactName": "Emusol-${version}-${os}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Emusol-${version}-${os}-${arch}.${ext}"
    }
  }
}
